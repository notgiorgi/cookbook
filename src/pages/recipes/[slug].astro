---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  return recipes.map((recipe) => ({
    params: { slug: recipe.id },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const { Content } = await render(recipe);
const baseUrl = `${import.meta.env.BASE_URL}`.endsWith('/') ? `${import.meta.env.BASE_URL}` : `${import.meta.env.BASE_URL}/`;
const homeUrl = recipe.data.tags[0]
  ? `${baseUrl}?tag=${encodeURIComponent(recipe.data.tags[0])}`
  : baseUrl;
const withBase = (path) => {
  if (!path) return path;
  if (/^https?:\/\//.test(path)) return path;
  return `${baseUrl}${path.replace(/^\//, '')}`;
};
---
<BaseLayout title={recipe.data.title}>
  <article class="rounded-[24px] border border-[color:var(--color-line)] bg-panel px-5 py-5 shadow-[var(--shadow-card)]">
    <div class="mb-6 no-print">
      <p class="mb-3"><a href={homeUrl}>← Back to all recipes</a></p>
      <div class="mb-4 flex items-center gap-3">
        <input id="wake-lock-toggle" type="checkbox" />
        <label for="wake-lock-toggle">Don’t lock my screen</label>
      </div>
      <p class="-mt-1 text-[0.95rem] text-mute" id="wake-lock-status"></p>
      <p class="text-[0.95rem] text-mute">Status: {recipe.data.status}</p>
      {recipe.data.tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-1.5">
          {recipe.data.tags.map((tag) => (
            <a class="inline-flex items-center whitespace-nowrap rounded-full border border-[rgba(154,79,47,0.08)] bg-[rgba(154,79,47,0.06)] px-2 py-1 text-[0.64rem] leading-none text-[rgba(108,47,23,0.72)] no-underline" href={`${baseUrl}?tag=${encodeURIComponent(tag)}`}>{tag}</a>
          ))}
        </div>
      )}
      <hr class="mt-6 border-0 border-t border-[color:var(--color-line)]" />
    </div>

    <h1 class="m-0">{recipe.data.title}</h1>

    {recipe.data.images?.length ? (
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {recipe.data.images.map((image) => (
          <figure class="overflow-hidden rounded-[20px] border border-[color:var(--color-line)] bg-panel-soft">
            <img
              src={withBase(image.src)}
              alt={image.alt || recipe.data.title}
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </figure>
        ))}
      </div>
    ) : recipe.data.image && (
      <figure class="mt-6 overflow-hidden rounded-[20px] border border-[color:var(--color-line)] bg-panel-soft">
        <img
          src={withBase(recipe.data.image)}
          alt={recipe.data.image_alt || recipe.data.title}
          class="h-auto w-full object-cover"
          loading="lazy"
        />
      </figure>
    )}

    <div class="prose prose-stone mt-6 max-w-none prose-headings:font-serif prose-headings:text-ink prose-h2:mt-10 prose-h2:mb-4 prose-h3:mt-10 prose-h3:mb-4 prose-h3:text-[1.22rem] prose-h3:font-semibold prose-ol:mt-3 prose-ol:mb-6 prose-ul:mt-3 prose-ul:mb-6 prose-li:my-2 prose-p:text-ink prose-li:text-ink prose-strong:text-ink prose-a:text-accent-strong">
      <Content />
    </div>

    {recipe.data.source_url && (
      <p class="no-print mt-8 text-[0.95rem] text-mute">
        Source: <a class="break-all" href={recipe.data.source_url}>Original recipe</a>
      </p>
    )}
  </article>

  <script>
    const ingredientLists = Array.from(document.querySelectorAll('ul.contains-task-list'));

    ingredientLists.forEach((list, listIndex) => {
      const items = Array.from(list.querySelectorAll('li.task-list-item'));
      items.forEach((item, itemIndex) => {
        const rendered = item.querySelector('input[type="checkbox"]');
        if (!rendered) return;

        const storageKey = `cookbook:${window.location.pathname}:ingredient:${listIndex}:${itemIndex}`;
        const checked = window.localStorage.getItem(storageKey) === 'true';
        const textNode = Array.from(item.childNodes).find((node) => node.nodeType === Node.TEXT_NODE && node.textContent.trim());
        const labelText = textNode ? textNode.textContent.trim() : item.textContent.trim();

        const interactive = document.createElement('input');
        interactive.type = 'checkbox';
        interactive.className = 'ingredient-check';
        interactive.checked = checked;

        const label = document.createElement('label');
        label.className = 'cursor-pointer';
        label.appendChild(interactive);
        label.append(document.createTextNode(labelText));

        interactive.addEventListener('change', () => {
          window.localStorage.setItem(storageKey, String(interactive.checked));
        });

        item.innerHTML = '';
        item.appendChild(label);
      });
    });

    const wakeToggle = document.querySelector('#wake-lock-toggle');
    const wakeStatus = document.querySelector('#wake-lock-status');
    let wakeLock = null;

    const setWakeStatus = (text) => {
      if (wakeStatus) wakeStatus.textContent = text;
    };

    const requestWakeLock = async () => {
      if (!('wakeLock' in navigator)) {
        setWakeStatus('Wake lock is not supported in this browser.');
        if (wakeToggle) wakeToggle.checked = false;
        return;
      }
      try {
        wakeLock = await navigator.wakeLock.request('screen');
        setWakeStatus('Screen will stay awake while this page is open.');
        wakeLock.addEventListener('release', () => {
          if (wakeToggle) wakeToggle.checked = false;
          setWakeStatus('Wake lock released.');
        });
      } catch (error) {
        setWakeStatus('Could not keep the screen awake here.');
        if (wakeToggle) wakeToggle.checked = false;
      }
    };

    if (wakeToggle) {
      wakeToggle.addEventListener('change', async () => {
        if (wakeToggle.checked) {
          await requestWakeLock();
        } else if (wakeLock) {
          await wakeLock.release();
          wakeLock = null;
          setWakeStatus('Wake lock turned off.');
        }
      });

      document.addEventListener('visibilitychange', async () => {
        if (document.visibilityState === 'visible' && wakeToggle.checked && !wakeLock) {
          await requestWakeLock();
        }
      });
    }
  </script>
</BaseLayout>
