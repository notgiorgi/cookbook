---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  return recipes.map((recipe) => ({
    params: { slug: recipe.id },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const { Content } = await render(recipe);
const homeUrl = `${import.meta.env.BASE_URL}`.endsWith('/') ? `${import.meta.env.BASE_URL}` : `${import.meta.env.BASE_URL}/`;
---
<BaseLayout title={recipe.data.title}>
  <article class="card">
    <div class="no-print">
      <p><a href={homeUrl}>← Back to all recipes</a></p>
      <div class="toggle-row">
        <input id="wake-lock-toggle" type="checkbox" />
        <label for="wake-lock-toggle">Don’t lock my screen</label>
      </div>
      <p class="meta" id="wake-lock-status" style="margin-top: -0.35rem;"></p>
      <p class="meta">Status: {recipe.data.status}</p>
      {recipe.data.tags.length > 0 && (
        <div class="tags">
          {recipe.data.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      )}
      <hr style="margin: 1.5rem 0; border: none; border-top: 1px solid #eadfd3;" />
    </div>

    <h1>{recipe.data.title}</h1>
    <Content />

    {recipe.data.source_url && (
      <p class="meta no-print" style="margin-top: 2rem;">Source: <a href={recipe.data.source_url}>{recipe.data.source_url}</a></p>
    )}
  </article>

  <script>
    const ingredientLists = Array.from(document.querySelectorAll('ul.contains-task-list'));

    ingredientLists.forEach((list, listIndex) => {
      const items = Array.from(list.querySelectorAll('li.task-list-item'));
      items.forEach((item, itemIndex) => {
        const rendered = item.querySelector('input[type="checkbox"]');
        if (!rendered) return;

        const storageKey = `cookbook:${window.location.pathname}:ingredient:${listIndex}:${itemIndex}`;
        const checked = window.localStorage.getItem(storageKey) === 'true';
        const textNode = Array.from(item.childNodes).find((node) => node.nodeType === Node.TEXT_NODE && node.textContent.trim());
        const labelText = textNode ? textNode.textContent.trim() : item.textContent.trim();

        const interactive = document.createElement('input');
        interactive.type = 'checkbox';
        interactive.className = 'ingredient-check';
        interactive.checked = checked;

        const label = document.createElement('label');
        label.className = 'ingredient-label';
        label.appendChild(interactive);
        label.append(document.createTextNode(labelText));

        interactive.addEventListener('change', () => {
          window.localStorage.setItem(storageKey, String(interactive.checked));
        });

        item.innerHTML = '';
        item.appendChild(label);
      });
    });

    const wakeToggle = document.querySelector('#wake-lock-toggle');
    const wakeStatus = document.querySelector('#wake-lock-status');
    let wakeLock = null;

    const setWakeStatus = (text) => {
      if (wakeStatus) wakeStatus.textContent = text;
    };

    const requestWakeLock = async () => {
      if (!('wakeLock' in navigator)) {
        setWakeStatus('Wake lock is not supported in this browser.');
        if (wakeToggle) wakeToggle.checked = false;
        return;
      }
      try {
        wakeLock = await navigator.wakeLock.request('screen');
        setWakeStatus('Screen will stay awake while this page is open.');
        wakeLock.addEventListener('release', () => {
          if (wakeToggle) wakeToggle.checked = false;
          setWakeStatus('Wake lock released.');
        });
      } catch (error) {
        setWakeStatus('Could not keep the screen awake here.');
        if (wakeToggle) wakeToggle.checked = false;
      }
    };

    if (wakeToggle) {
      wakeToggle.addEventListener('change', async () => {
        if (wakeToggle.checked) {
          await requestWakeLock();
        } else if (wakeLock) {
          await wakeLock.release();
          wakeLock = null;
          setWakeStatus('Wake lock turned off.');
        }
      });

      document.addEventListener('visibilitychange', async () => {
        if (document.visibilityState === 'visible' && wakeToggle.checked && !wakeLock) {
          await requestWakeLock();
        }
      });
    }
  </script>
</BaseLayout>
