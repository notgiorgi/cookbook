---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const recipes = (await getCollection('recipes'))
  .map((recipe) => ({
    ...recipe,
    slug: recipe.id,
  }))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
const published = recipes.filter((recipe) => recipe.data.status === 'published');
const drafts = recipes.filter((recipe) => recipe.data.status !== 'published');
const withBase = (path) => `${import.meta.env.BASE_URL}${path}`.replace('/cookbookrecipes/', '/cookbook/recipes/');
const categories = ['breakfast', 'main', 'side', 'dessert'];
const grouped = Object.fromEntries(
  categories.map((category) => [
    category,
    published.filter((recipe) => recipe.data.tags.includes(category)),
  ])
);
---
<BaseLayout title="Cookbook">
  <section class="card" style="margin-bottom: 1rem;">
    <p class="meta">A tidy little recipe archive.</p>
    <p>{published.length} published recipes, {drafts.length} drafts.</p>
    <input
      id="recipe-search"
      class="search-input"
      type="search"
      placeholder="Search recipes, tags, ingredients..."
      aria-label="Search recipes"
      style="margin-top: 1rem;"
    />
  </section>

  {categories.map((category) => (
    <section style="margin-bottom: 2rem;" data-category-section={category}>
      <h2 style="text-transform: capitalize;">{category}</h2>
      <div class="grid">
        {grouped[category].map((recipe) => (
          <article
            class="card recipe-card"
            data-searchable
            data-title={recipe.data.title.toLowerCase()}
            data-tags={recipe.data.tags.join(' ').toLowerCase()}
          >
            <h3><a href={withBase(`recipes/${recipe.slug}/`)}>{recipe.data.title}</a></h3>
            <div class="tags">
              {recipe.data.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          </article>
        ))}
      </div>
    </section>
  ))}

  <section data-category-section="drafts">
    <h2>Drafts</h2>
    <div class="grid">
      {drafts.map((recipe) => (
        <article
          class="card recipe-card"
          data-searchable
          data-title={recipe.data.title.toLowerCase()}
          data-tags={recipe.data.tags.join(' ').toLowerCase()}
        >
          <h3><a href={withBase(`recipes/${recipe.slug}/`)}>{recipe.data.title}</a></h3>
          <div class="tags">
            {recipe.data.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>

  <script>
    const input = document.querySelector('#recipe-search');
    const cards = Array.from(document.querySelectorAll('[data-searchable]'));
    const sections = Array.from(document.querySelectorAll('[data-category-section]'));

    if (input) {
      input.addEventListener('input', () => {
        const query = input.value.trim().toLowerCase();

        cards.forEach((card) => {
          const haystack = `${card.dataset.title || ''} ${card.dataset.tags || ''}`;
          const match = !query || haystack.includes(query);
          card.style.display = match ? '' : 'none';
        });

        sections.forEach((section) => {
          const visibleCards = section.querySelectorAll('.recipe-card:not([style*="display: none"])');
          section.style.display = visibleCards.length ? '' : 'none';
        });
      });
    }
  </script>
</BaseLayout>
