---
import '../styles/global.css';

const { title = 'Cookbook' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <div class="mx-auto max-w-[1080px] px-4 pb-16 pt-3 sm:pt-4">
      <header class="mb-4 py-1 sm:mb-5">
        <a class="inline-flex items-baseline gap-2 text-inherit no-underline" href={`${import.meta.env.BASE_URL}`}>
          <span class="text-[0.72rem] uppercase tracking-[0.16em] text-mute sm:text-[0.75rem]">Cookbook</span>
          <h1 class="m-0 text-[1.2rem] sm:text-[1.45rem]">Gio’s recipes</h1>
        </a>
      </header>
      <slot />
      <footer class="mt-12 border-t border-[color:var(--color-line)] pt-4 text-[0.95rem] text-mute">
        Recipes here come from all over the place. I do not claim ownership of them, and I make a best effort to attribute sources when I have them.
      </footer>
    </div>
  </body>
</html>
