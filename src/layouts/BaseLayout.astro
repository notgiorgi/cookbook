---
const { title = 'Cookbook' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #f5efe6;
        --bg-accent: #efe3d3;
        --panel: rgba(255, 250, 244, 0.88);
        --panel-strong: #fffaf4;
        --text: #251c16;
        --muted: #7a675a;
        --accent: #9a4f2f;
        --accent-strong: #6c2f17;
        --accent-soft: #ead2bf;
        --border: rgba(142, 101, 73, 0.18);
        --shadow: 0 18px 50px rgba(77, 45, 24, 0.08);
      }
      * { box-sizing: border-box; }
      html {
        background:
          radial-gradient(circle at top, rgba(255, 255, 255, 0.6), transparent 35%),
          linear-gradient(180deg, var(--bg-accent) 0%, var(--bg) 18%, #f8f3ed 100%);
      }
      body {
        margin: 0;
        font-family: Georgia, Cambria, "Times New Roman", Times, serif;
        background: transparent;
        color: var(--text);
        line-height: 1.6;
      }
      a {
        color: var(--accent-strong);
        text-underline-offset: 0.14em;
      }
      .wrap {
        max-width: 1080px;
        margin: 0 auto;
        padding: 1rem 1rem 4rem;
      }
      header {
        margin-bottom: 0.9rem;
        padding: 0.2rem 0 0.35rem;
      }
      .home {
        display: inline-flex;
        align-items: baseline;
        gap: 0.5rem;
        text-decoration: none;
        color: inherit;
      }
      .home h1 {
        margin: 0;
        font-size: clamp(1.15rem, 1.8vw, 1.45rem);
        letter-spacing: -0.03em;
      }
      .home-mark {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: var(--muted);
      }
      .card {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 1.25rem;
        box-shadow: var(--shadow);
        backdrop-filter: blur(10px);
      }
      .grid {
        display: grid;
        gap: 1rem;
      }
      .recipe-grid {
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      }
      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 0.9rem;
      }
      .tag {
        display: inline-flex;
        align-items: center;
        white-space: nowrap;
        font-size: 0.72rem;
        line-height: 1;
        padding: 0.34rem 0.62rem;
        border-radius: 999px;
        background: color-mix(in srgb, var(--accent-soft) 72%, white 28%);
        color: var(--accent-strong);
        border: 1px solid rgba(154, 79, 47, 0.14);
        text-decoration: none;
      }
      .tag-button {
        cursor: pointer;
        font: inherit;
        transition: background 140ms ease, color 140ms ease, transform 140ms ease;
      }
      .tag-button:hover {
        transform: translateY(-1px);
      }
      .tag-button.active {
        background: var(--accent);
        color: #fff7f0;
        border-color: var(--accent);
      }
      .meta {
        color: var(--muted);
        font-size: 0.95rem;
      }
      .eyebrow {
        margin: 0 0 0.4rem;
        color: var(--muted);
        font-size: 0.78rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }
      .search-input {
        width: 100%;
        padding: 0.95rem 1rem;
        border-radius: 16px;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.82);
        color: var(--text);
        font: inherit;
      }
      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.78rem 1rem;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: #f8ecdf;
        color: var(--accent-strong);
        text-decoration: none;
        font: inherit;
        cursor: pointer;
      }
      .button:hover {
        background: #f2e1d0;
      }
      .button-primary {
        background: var(--accent);
        color: #fff7f0;
        border-color: transparent;
      }
      .button-primary:hover {
        background: #8b4427;
      }
      .button-ghost {
        background: rgba(255, 255, 255, 0.7);
      }
      .stat-pill {
        display: inline-flex;
        align-items: center;
        padding: 0.45rem 0.7rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.55);
        border: 1px solid var(--border);
      }
      .text-link {
        text-decoration: none;
      }
      .search-input:focus {
        outline: 2px solid rgba(154, 79, 47, 0.28);
        outline-offset: 2px;
      }
      h1, h2, h3 { line-height: 1.15; }
      h2, h3 {
        margin: 0;
        letter-spacing: -0.03em;
      }
      ul, ol { padding-left: 1.2rem; }
      ul.contains-task-list {
        list-style: none;
        padding-left: 0;
      }
      ul.contains-task-list li.task-list-item {
        list-style: none;
      }
      ul.contains-task-list li.task-list-item::marker {
        content: '';
      }
      ul.contains-task-list input[type='checkbox'] {
        width: 1.05rem;
        height: 1.05rem;
        margin-right: 0.65rem;
        vertical-align: -0.12rem;
      }
      .ingredient-check {
        width: 1.05rem;
        height: 1.05rem;
        margin-right: 0.65rem;
        vertical-align: -0.12rem;
      }
      .ingredient-label {
        cursor: pointer;
      }
      .toggle-row {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        margin: 0.75rem 0 1rem;
      }
      .hero-panel {
        display: grid;
        gap: 1rem;
        grid-template-columns: minmax(0, 1fr) minmax(280px, 0.95fr);
        align-items: center;
        margin-bottom: 1.5rem;
        padding: 1.15rem 1.25rem;
        border-radius: 28px;
        border: 1px solid rgba(142, 101, 73, 0.16);
        background:
          linear-gradient(135deg, rgba(255, 250, 244, 0.92), rgba(247, 237, 226, 0.84)),
          radial-gradient(circle at top left, rgba(255, 255, 255, 0.9), transparent 35%);
        box-shadow: var(--shadow);
      }
      .hero-panel-compact {
        grid-template-columns: minmax(0, 1fr) minmax(300px, 1.1fr);
      }
      .hero-copy-block {
        max-width: 26rem;
      }
      .hero-title {
        margin: 0;
        font-size: clamp(1.7rem, 4vw, 2.6rem);
        max-width: 11ch;
      }
      .hero-copy {
        margin: 0.45rem 0 0;
        max-width: 32ch;
        color: var(--muted);
      }
      .hero-controls {
        display: grid;
        gap: 0.75rem;
      }
      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        align-items: center;
      }
      .section-heading {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: end;
        margin-bottom: 1rem;
      }
      .recipe-card {
        display: grid;
        gap: 1rem;
        align-content: start;
        min-height: 0;
        padding: 1.1rem 1.1rem 1.2rem;
        background:
          linear-gradient(180deg, rgba(255, 252, 248, 0.96), rgba(248, 240, 230, 0.88));
        transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
      }
      .recipe-card:hover {
        transform: translateY(-3px);
        border-color: rgba(154, 79, 47, 0.26);
        box-shadow: 0 20px 46px rgba(77, 45, 24, 0.12);
      }
      .recipe-card-top {
        display: grid;
        gap: 0.65rem;
      }
      .recipe-date {
        margin: 0;
        font-size: 0.82rem;
      }
      .recipe-tags {
        margin-top: 0;
      }
      .recipe-title {
        margin-top: 0;
        font-size: 1.5rem;
      }
      .recipe-title a {
        color: inherit;
        text-decoration: none;
      }
      .recipe-title a:hover {
        color: var(--accent-strong);
      }

      @media (max-width: 760px) {
        .wrap {
          padding-top: 0.6rem;
        }
        .home {
          gap: 0.45rem;
        }
        .home h1 {
          font-size: 1.2rem;
        }
        .home-mark {
          font-size: 0.72rem;
        }
        .hero-panel {
          grid-template-columns: 1fr;
          padding: 1rem;
          margin-bottom: 1.25rem;
        }
        .hero-title {
          font-size: 1.9rem;
          max-width: 10ch;
        }
        .hero-copy {
          font-size: 1rem;
        }
        .hero-actions {
          gap: 0.55rem;
        }
        .hero-actions > * {
          flex: 0 0 auto;
        }
        .recipe-card {
          gap: 0.85rem;
        }
        .section-heading {
          flex-direction: column;
          align-items: start;
        }
      }

      @media print {
        html,
        body {
          background: white;
          color: black;
        }
        .wrap {
          max-width: none;
          padding: 0;
        }
        header,
        .no-print,
        .no-print * {
          display: none !important;
        }
        .card,
        .hero-panel {
          background: transparent;
          border: 0;
          border-radius: 0;
          padding: 0;
          box-shadow: none;
        }
        a {
          color: inherit;
          text-decoration: none;
        }
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header>
        <a class="home" href={`${import.meta.env.BASE_URL}`}>
          <span class="home-mark">Cookbook</span>
          <h1>Gio’s recipes</h1>
        </a>
      </header>
      <slot />
      <footer class="meta" style="margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--border);">
        Recipes here come from all over the place. I do not claim ownership of them, and I make a best effort to attribute sources when I have them.
      </footer>
    </div>
  </body>
</html>
