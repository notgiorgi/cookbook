---
const { title = 'Cookbook' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #faf7f2;
        --panel: #fffdf9;
        --text: #2a241f;
        --muted: #6f655c;
        --accent: #8d4e2f;
        --border: #eadfd3;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
      }
      a { color: var(--accent); }
      .wrap {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 1rem 4rem;
      }
      header { margin-bottom: 2rem; }
      .home {
        text-decoration: none;
        color: inherit;
      }
      .card {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.25rem;
      }
      .grid {
        display: grid;
        gap: 1rem;
      }
      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
        margin-top: 0.9rem;
      }
      .tag {
        display: inline-flex;
        align-items: center;
        white-space: nowrap;
        font-size: 0.85rem;
        line-height: 1;
        padding: 0.38rem 0.72rem;
        border-radius: 999px;
        background: #f3e7dd;
        color: #6f3d24;
        border: 1px solid #ead4c4;
      }
      .meta {
        color: var(--muted);
        font-size: 0.95rem;
      }
      .search-input {
        width: 100%;
        padding: 0.9rem 1rem;
        border-radius: 12px;
        border: 1px solid var(--border);
        background: #fff;
        color: var(--text);
        font: inherit;
      }
      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.7rem 1rem;
        border-radius: 12px;
        border: 1px solid var(--border);
        background: #f3e7dd;
        color: #6f3d24;
        text-decoration: none;
        font: inherit;
        cursor: pointer;
      }
      .button:hover {
        background: #ecdacb;
      }
      .search-input:focus {
        outline: 2px solid #d8b49b;
        outline-offset: 2px;
      }
      h1, h2, h3 { line-height: 1.2; }
      ul, ol { padding-left: 1.2rem; }

      @media print {
        body {
          background: white;
          color: black;
        }
        .wrap {
          max-width: none;
          padding: 0;
        }
        header,
        .no-print,
        .no-print * {
          display: none !important;
        }
        .card {
          background: transparent;
          border: 0;
          border-radius: 0;
          padding: 0;
          box-shadow: none;
        }
        a {
          color: inherit;
          text-decoration: none;
        }
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header>
        <a class="home" href={`${import.meta.env.BASE_URL}`}>
          <h1>Cookbook</h1>
        </a>
      </header>
      <slot />
      <footer class="meta" style="margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--border);">
        Recipes here come from all over the place. I do not claim ownership of them, and I make a best effort to attribute sources when I have them.
      </footer>
    </div>
  </body>
</html>
